<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    
    <xacro:include filename = "inertia_macros.xacro"/>

    <!-- Materials -->

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.65 0 1"/>
    </material>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- Base Link-->

    <link name="base_link"> </link>

    <!-- Chassis Link -->

    <link name="chassis">
        <visual>
            <origin xyz="0 0 0.0215"/>
            <geometry>
                <box size="0.048 0.048 0.043"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.0215"/>
            <geometry>
                <box size="0.048 0.048 0.043"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass = "0.5" x = "0.048" y = "0.048" z = "0.043">
            <origin xyz = "0 0 0.0215" rpy = "0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material> 
            Gazebo/Black 
        </material>
    </gazebo>

    <!-- Chassis/Base Joint -->

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 -0.043"/>
    </joint>

    <!-- Shaft Link -->

    <link name="shaft_link">
        <visual>
            <origin xyz="0 0 0.018"/>
            <geometry>
                <cylinder radius="0.01" length="0.036"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.018"/>
            <geometry>
                <cylinder radius="0.01" length="0.036"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.036" radius = "0.01">
            <origin xyz = "0 0 0.018" rpy = "0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="shaft_link">
        <material> 
            Gazebo/Orange 
        </material>
    </gazebo>

    <!-- Shaft Joint -->

    <joint name="shaft_joint" type="continuous">
        <parent link="base_link"/>
        <child link="shaft_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz=" 0 0 1"/>
    </joint>

    <!-- Bracket Link -->

    <link name="bracket_link">
        <visual>
            <origin xyz="-0.012 0 0"/>
            <geometry>
                <box size="0.045 0.03 0.01"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="-0.012 0 0"/>
            <geometry>
                <box size="0.045 0.03 0.01"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass = "0.1" x = "0.045" y = "0.03" z = "0.01">
            <origin xyz = "0 -0.012 0" rpy = "0 0 0"/>
        </xacro:inertial_box>
        <visual>
            <origin xyz="-0.0255 0 0.045" rpy="0 ${pi/2} 0"/>
            <geometry>
                <cylinder radius="0.0415" length="0.018"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="-0.0255 0 0.045" rpy="0 ${pi/2} 0"/>
            <geometry>
                <cylinder radius="0.0415" length="0.018"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass = "0.1" length = "0.018" radius = "0.0415">
            <origin xyz = "-0.0255 0 0.045" rpy="0 ${pi/2} 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="bracket_link">
        <material> 
            Gazebo/White 
        </material>
    </gazebo>

    <!-- Bracket Joint -->

    <joint name="bracket_joint" type="fixed">
        <parent link="shaft_link"/>
        <child link="bracket_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

</robot>